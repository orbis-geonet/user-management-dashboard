# Frontend environment variables.
# Copy this file to `front-app/.env` and fill in real values.

# Backend API base URL used by the dashboard
REACT_APP_BACK_URL=http://localhost:8080/api/v1
# Optional alternate/remote backend URL
REACT_APP_BACK_URL_1=https://your-backend-host/api/v1

# Google Maps / Places browser API key
REACT_APP_GOOGLE_KEY=AIzaSyDUMMYDUMMYDUMMYDUMMYDUMMYDUMMYDUM
# Public bucket URL for user/place images
REACT_APP_GOOGLE_IMG_URL=https://storage.googleapis.com/your-bucket.appspot.com

# Firebase web app config
REACT_APP_FIRE_BASE_STORAGE_BUCKET=your-project.appspot.com
REACT_APP_FIRE_BASE_PROJECT_ID=your-project
REACT_APP_FIRE_BASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIRE_BASE_DATA_BASE_URL=https://your-project-default-rtdb.firebaseio.com
REACT_APP_FIRE_BASE_MESSAGING_SENDER_ID=000000000000
REACT_APP_FIRE_BASE_APP_IP=1:000000000000:web:0000000000000000000000
REACT_APP_FIRE_BASE_MEASUREMENT_ID=G-XXXXXXXXXX
